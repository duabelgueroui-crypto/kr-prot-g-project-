    <!-- http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#hasdefinition -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#hasdefinition">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#semantic_representation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#hasgoal -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#hasgoal">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#semantic_web"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#isformal -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#isformal">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#semantic_representation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#supporysinference -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#supporysinference">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#semantic_representation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


