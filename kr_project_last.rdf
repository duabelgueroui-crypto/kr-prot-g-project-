     -->

    


    <!-- http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#FirstOrder_logic -->

    <owl:Class rdf:about="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#FirstOrder_logic">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#classical_logic"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#usesfunction"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#function"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#usespredicate"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#predicate"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#usesquantifier"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#quantifier"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#OWL -->

    <owl:Class rdf:about="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#OWL">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#language"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#RDF -->

    <owl:Class rdf:about="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#RDF">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#language"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#RDFS -->

    <owl:Class rdf:about="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#RDFS">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#language"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#WFF -->

    <owl:Class rdf:about="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#WFF">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#hascomponent"/>
                                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#logicalconnectives"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#hascomponent"/>
                                <owl:someValuesFrom>
                                    <owl:Class>
                                        <owl:intersectionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#constants"/>
                                            <rdf:Description rdf:about="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#variables"/>
                                        </owl:intersectionOf>
                                    </owl:Class>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#hascomponent"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#constants"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#hascomponent"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#variables"/>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#syntax"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#hasstatus"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#contradiction"/>
                            <rdf:Description rdf:about="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#satisfiable"/>
                            <rdf:Description rdf:about="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#tautology"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#axioms -->

    <owl:Class rdf:about="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#axioms"/>
    


