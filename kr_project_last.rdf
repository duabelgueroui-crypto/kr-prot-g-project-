                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#WFF"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#hasconsequent"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#WFF"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#hasjustification"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#WFF"/>
