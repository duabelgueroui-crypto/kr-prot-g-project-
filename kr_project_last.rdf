                <owl:allValuesFrom rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#extention"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#default_theory -->

    <owl:Class rdf:about="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#default_theory">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#based_on"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#defaultrule"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#hasfacts"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#WFF"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#defaultrule -->

