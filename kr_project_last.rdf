    <owl:Class rdf:about="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#contradiction">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#semantic_classification"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#satisfiable"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/pc/ontologies/2026/4/untitled-ontology-2#tautology"/>
